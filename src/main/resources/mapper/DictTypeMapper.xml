<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.github.starhq.template.mapper.SysDictTypeMapper">

    <resultMap id="dictTypeResultMap" type="com.github.starhq.template.model.vo.dict.type.DictTypeWithDataVO">
        <result property="dictType" column="type"/>
        <collection property="dataList" ofType="com.github.starhq.template.model.vo.dict.type.DictDataVO">
            <result property="dictLabel" column="dd_label"/>
            <result property="dictValue" column="dd_value"/>
        </collection>
    </resultMap>

    <select id="selectDictTypesWithData" resultMap="dictTypeResultMap">
        SELECT dt.type  AS type,
               dd.label AS dd_label,
               dd.value AS dd_value
        FROM sys_dict_type dt
                 LEFT JOIN sys_dict_data dd ON dt.id = dd.type_id
    </select>
</mapper>