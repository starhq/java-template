<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.github.starhq.template.mapper.SysUserMapper">

    <resultMap id="UserWithRolesMap" type="user">
        <id property="id" column="user_id"/>
        <result property="username" column="username"/>
        <result property="status" column="status"/>

        <collection property="authorities" ofType="role">
            <id property="id" column="role_id"/>
            <result property="code" column="role_code"/>
        </collection>
    </resultMap>

    <select id="selectUserWithRole" resultMap="UserWithRolesMap">
          SELECT u.id   AS user_id,
                 u.username,
                 u.status,
                 r.id   AS role_id,
                 r.code AS role_code
          FROM sys_user u
                   LEFT JOIN sys_user_role ur ON u.id = ur.user_id
                   LEFT JOIN sys_role r ON ur.role_id = r.id
              ${ew.customSqlSegment}
    </select>
</mapper>