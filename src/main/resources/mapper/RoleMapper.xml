<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.github.starhq.template.mapper.SysRoleMapper">

    <select id="selectRolesByUserId" resultType="com.github.starhq.template.model.vo.role.RoleCheckVO">
        SELECT
            r.id,
            r.name,
            <choose>
               <when test="userId != null">
                    CASE WHEN ur.user_id IS NOT NULL THEN true ELSE false END AS checked
               </when>
               <otherwise>
                   false AS checked
               </otherwise>
           </choose>
        FROM sys_role r
          <if test="userId != null">
                 LEFT JOIN sys_user_role ur
                           ON r.id = ur.role_id
                               AND ur.user_id = #{userId}
        </if>
        ORDER BY r.id
    </select>

</mapper>